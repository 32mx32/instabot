# Токен вашего Telegram-бота (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Один ключ API Apify (старый формат, поддерживается для совместимости)
APIFY_API_KEY=YOUR_APIFY_API_KEY

# Несколько ключей API Apify через запятую.
# Если один ключ упрется в лимит/квоту, бот попробует следующий.
# APIFY_API_KEYS=apify_api_key_1,apify_api_key_2,apify_api_key_3

# Удалять файлы после отправки (true/false)
DELETE_AFTER_SEND=true
